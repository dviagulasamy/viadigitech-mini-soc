# ─── ViaDigiTech Mini-SOC — Variables d'environnement ──────────────────────
# Copier ce fichier en .env (ou /etc/soc-actions.env) et remplir les valeurs.
# NE JAMAIS commiter le fichier .env — il est ignoré par .gitignore
# ───────────────────────────────────────────────────────────────────────────

# ── Threat Intelligence ──────────────────────────────────────────────────────
# Clé AbuseIPDB (gratuit : https://www.abuseipdb.com/account/api)
ABUSEIPDB_KEY=your_abuseipdb_key_here

# Clé AlienVault OTX (optionnel : https://otx.alienvault.com)
OTX_KEY=your_otx_key_here

# ── AnythingLLM RAG ──────────────────────────────────────────────────────────
ANYTHINGLLM_KEY=your_anythingllm_api_key_here
ANYTHINGLLM_WORKSPACE=your_workspace_slug_here

# ── API SOC Actions ──────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SOC_ACTIONS_KEY=your_random_hex_key_here

# ── Dashboard ────────────────────────────────────────────────────────────────
# Mot de passe d'accès au dashboard SOC
SOC_DASHBOARD_PWD=your_strong_password_here

# ── Email ────────────────────────────────────────────────────────────────────
SOC_MAIL_FROM=secops@yourdomain.com
SOC_MAIL_TO=admin@yourdomain.com

# ── Telegram (optionnel) ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── URLs internes (adapter si ports différents) ───────────────────────────────
OLLAMA_URL=http://localhost:11434
ACTIONS_API_URL=http://localhost:8022
ANYTHINGLLM_URL=http://localhost:3101
